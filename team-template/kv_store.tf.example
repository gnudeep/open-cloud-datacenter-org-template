# ══════════════════════════════════════════════════════════════
# KV Store (Redis or Consul) — SYSTEM VLAN
#
# This file provisions a KV store VM in the SYSTEM VLAN alongside
# Vault and the container registry.
#
# Static IP addressing:
#   kv store = cidrhost(system.cidr, 10)  e.g. 10.N.2.10
#   (DHCP pool starts at .100 — .10-.99 are reserved for service VMs)
#
# DNS name (served by VyOS from day 1):
#   redis.sre-<team>.internal  → 10.N.2.10
#
# Choose ONE of the two options below:
#   Option A: Redis (default) — simple key-value cache/store
#   Option B: Consul           — service mesh, distributed KV, health-check
#
# Traffic notes:
#   - K8s pods in PRIVATE VLAN reach the KV store via VyOS PRIV-TO-SYS rule 40
#     (port set in var.kv_store_port: 6379 = Redis, 8500 = Consul)
#
# Usage:
#   cp kv_store.tf.example kv_store.tf
#   # Set kv_store_port in terraform.tfvars (6379 or 8500)
#   terraform init && terraform apply
# ══════════════════════════════════════════════════════════════

locals {
  kv_ip     = cidrhost(var.vlans.system.cidr, 10)
  kv_prefix = split("/", var.vlans.system.cidr)[1]
}

# ══════════════════════════════════════════════════════════════
# OPTION A: Redis
# ══════════════════════════════════════════════════════════════

resource "harvester_cloudinit_secret" "redis" {
  name      = "redis-cloudinit"
  namespace = var.namespace

  # Static IP — matches VyOS static-host-mapping for redis.${dns_domain}
  # Interface name is enp1s0 for virtio-net on KubeVirt/Harvester.
  network_data = <<-NETDATA
    version: 2
    ethernets:
      enp1s0:
        addresses:
          - ${local.kv_ip}/${local.kv_prefix}
        gateway4: ${var.vlans.system.gateway}
        nameservers:
          addresses:
            - ${var.vlans.system.gateway}
          search:
            - ${var.dns_domain}
  NETDATA

  user_data = <<-USERDATA
    #cloud-config
    hostname: redis
    fqdn: redis.${var.dns_domain}
    manage_etc_hosts: true
    packages:
      - redis-server
    write_files:
      - path: /etc/redis/redis.conf
        content: |
          bind 0.0.0.0
          protected-mode yes
          port ${var.kv_store_port}
          # Require password in production — use Vault for secret injection
          requirepass ""
          save 900 1
          save 300 10
          save 60 10000
    runcmd:
      - systemctl enable redis-server
      - systemctl restart redis-server
    ssh_authorized_keys:
      - ${var.ssh_public_key}
  USERDATA
}

resource "harvester_virtualmachine" "redis" {
  name      = "${var.namespace}-redis"
  namespace = var.namespace

  cpu    = 2
  memory = "4Gi"

  disk {
    name        = "rootdisk"
    type        = "disk"
    size        = "20Gi"
    bus         = "virtio"
    boot_order  = 1
    image       = "ubuntu-22.04-server-cloudimg-amd64"
    auto_delete = true
  }

  network_interface {
    name         = "nic-system"
    network_name = harvester_network.vlans["system"].id
  }

  cloudinit {
    user_data_secret_name    = harvester_cloudinit_secret.redis.name
    network_data_secret_name = harvester_cloudinit_secret.redis.name
  }

  tags = {
    "role"       = "kv-store-redis"
    "service-ip" = local.kv_ip
  }
}

output "redis_ip" {
  value       = local.kv_ip
  description = "Redis static IP — resolves as redis.${var.dns_domain}"
}

output "redis_dns_name" {
  value       = "redis.${var.dns_domain}"
  description = "Redis DNS name — use this in app configuration instead of the IP"
}

# ══════════════════════════════════════════════════════════════
# OPTION B: Consul (comment out OPTION A above and uncomment this)
# Remember to set kv_store_port = 8500 in terraform.tfvars
# ══════════════════════════════════════════════════════════════

