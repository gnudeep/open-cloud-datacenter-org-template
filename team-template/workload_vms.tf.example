# ══════════════════════════════════════════════════════════════
# Example: Workload VMs on VPC VLANs
#
# This file shows how to create VMs on each VLAN zone
# after the VPC network and VyOS router are deployed.
# Uncomment and customize as needed.
# ══════════════════════════════════════════════════════════════

# ── Ubuntu base image for workload VMs ──
# resource "harvester_image" "ubuntu" {
#   name         = "ubuntu-2404"
#   namespace    = var.namespace
#   display_name = "Ubuntu 24.04 LTS Cloud"
#   source_type  = "download"
#   url          = "https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
#
#   timeouts {
#     create = "15m"
#   }
# }

