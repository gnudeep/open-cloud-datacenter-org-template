# ══════════════════════════════════════════════════════════════
# team-template/terraform.tfvars — Fill in from your team allocation
# See AGENT.md Section 6.3 for full reference
# ══════════════════════════════════════════════════════════════

# Kubeconfig provided by platform team (namespace-scoped)
harvester_kubeconfig = "../kubeconfig-sre-yourteam.yaml"

# Your namespace (created by platform team)
namespace = "sre-yourteam"

# Shared cluster network name — do NOT change, platform team owns this
cluster_network_name = "vpc-trunk"

# ── Harvester node list — ask platform team for exact names ──
harvester_node_names = [
  "harvester-node-0",
  "harvester-node-1",
  "harvester-node-2",
]
uplink_nics = ["eth1"]
bond_mode   = "active-backup"

# ══════════════════════════════════════════════════════════════
# VLAN Allocation — Replace with values from your team row in AGENT.md
#
# Example below is for sre-beta (team offset N=2):
#   public_vlan  = 100 + (2-1)*10 = 110
#   private_vlan = 200 + (2-1)*10 = 210
#   system_vlan  = 300 + (2-1)*10 = 310
#   data_vlan    = 400 + (2-1)*10 = 410
#   subnet block = 10.2.0.0/22
# ══════════════════════════════════════════════════════════════
vlans = {
  public = {
    vlan_id = 110            # 100 + (N-1)*10
    cidr    = "10.2.0.0/24"
    gateway = "10.2.0.1"
  }
  private = {
    vlan_id = 210            # 200 + (N-1)*10
    cidr    = "10.2.1.0/24"
    gateway = "10.2.1.1"
  }
  system = {
    vlan_id = 310            # 300 + (N-1)*10
    cidr    = "10.2.2.0/24"
    gateway = "10.2.2.1"
  }
  data = {
    vlan_id = 410            # 400 + (N-1)*10
    cidr    = "10.2.3.0/24"
    gateway = "10.2.3.1"
  }
}

# ── Management network ──
mgmt_network_gateway = "192.168.1.1"    # Your gateway (ask platform team)
vyos_mgmt_ip         = "192.168.1.20"  # 192.168.1.(N*10) — from your allocation
vyos_mgmt_cidr       = "24"

# ── VyOS Router VM sizing ──
vyos_cpu       = 2
vyos_memory    = "2Gi"
vyos_disk_size = "10Gi"

# ── Your team SSH public key (for VyOS access) ──
ssh_public_key = "ssh-ed25519 AAAA... replace-with-your-team-key"

# ── DNS ──
upstream_dns = ["8.8.8.8", "1.1.1.1"]

# Internal DNS zone — VMs become resolvable as <hostname>.<dns_domain>
# e.g. pg-primary.sre-yourteam.internal, redis.sre-yourteam.internal
dns_domain = "sre-yourteam.internal"

# ══════════════════════════════════════════════════════════════
# Workload Stack — Rancher + KV Store
# ══════════════════════════════════════════════════════════════

# Rancher management server (provided by platform team)
rancher_url        = "https://rancher.example.com"
rancher_access_key = "token-xxxxx"    # from Rancher API Keys page
rancher_secret_key = "xxxxxxxxxxxxxxxx"
rancher_insecure   = false

# CIDR of the Rancher/management network; VyOS opens port 6443 inbound from here
rancher_mgmt_cidr = "192.168.1.0/24"

# KV store port in SYSTEM VLAN: 6379 = Redis (default), 8500 = Consul
kv_store_port = 6379
