# ══════════════════════════════════════════════════════════════
# PostgreSQL Primary-Standby HA — DATA VLAN
#
# This file provisions two VMs in the DATA VLAN:
#   - postgresql-primary: accepts reads + writes
#   - postgresql-standby: streaming replication from primary
#
# Static IP addressing:
#   primary  = cidrhost(data.cidr, 10)  e.g. 10.N.3.10
#   standby  = cidrhost(data.cidr, 11)  e.g. 10.N.3.11
#   (DHCP pool starts at .100 — .10-.99 are reserved for service VMs)
#
# DNS names (served by VyOS from day 1):
#   postgres.sre-<team>.internal    → primary IP
#   postgres-ro.sre-<team>.internal → standby IP
#
# Traffic notes:
#   - Replication traffic is intra-VLAN (L2), does NOT cross VyOS
#   - K8s pods in PRIVATE VLAN reach port 5432 via VyOS PRIV-TO-DATA rule
#   - Vault in SYSTEM VLAN reaches port 5432 via VyOS SYS-TO-DATA rule
#
# Usage:
#   cp postgresql_ha.tf.example postgresql_ha.tf
#   # Set variables below and run:
#   terraform init && terraform apply
# ══════════════════════════════════════════════════════════════

locals {
  pg_primary_ip = cidrhost(var.vlans.data.cidr, 10)
  pg_standby_ip = cidrhost(var.vlans.data.cidr, 11)
  pg_prefix     = split("/", var.vlans.data.cidr)[1]
}

variable "pg_version" {
  description = "PostgreSQL major version"
  type        = string
  default     = "16"
}

variable "pg_password" {
  description = "PostgreSQL superuser password (use Vault in production)"
  type        = string
  sensitive   = true
}

variable "pg_replication_password" {
  description = "PostgreSQL replication user password"
  type        = string
  sensitive   = true
}

# ── Cloud-init: primary node ──
resource "harvester_cloudinit_secret" "pg_primary" {
  name      = "postgresql-primary-cloudinit"
  namespace = var.namespace

  # Static IP via cloud-init network data.
  # Interface name is enp1s0 for virtio-net on KubeVirt/Harvester.
  # If your image uses a different name, check with: ip link show
  network_data = <<-NETDATA
    version: 2
    ethernets:
      enp1s0:
        addresses:
          - ${local.pg_primary_ip}/${local.pg_prefix}
        gateway4: ${var.vlans.data.gateway}
        nameservers:
          addresses:
            - ${var.vlans.data.gateway}
          search:
            - ${var.dns_domain}
  NETDATA

  user_data = <<-USERDATA
    #cloud-config
    hostname: postgres
    fqdn: postgres.${var.dns_domain}
    manage_etc_hosts: true
    packages:
      - postgresql-${var.pg_version}
    write_files:
      - path: /etc/postgresql/${var.pg_version}/main/pg_hba.conf
        content: |
          local   all             postgres                                peer
          local   all             all                                     md5
          host    all             all             ${var.vlans.private.cidr}  md5
          host    all             all             ${var.vlans.system.cidr}   md5
          host    replication     replicator      ${var.vlans.data.cidr}     md5
      - path: /etc/postgresql/${var.pg_version}/main/conf.d/replication.conf
        content: |
          wal_level = replica
          max_wal_senders = 5
          wal_keep_size = 64MB
          hot_standby = on
          listen_addresses = '*'
    runcmd:
      - systemctl enable postgresql
      - systemctl start postgresql
      - sudo -u postgres psql -c "ALTER USER postgres PASSWORD '${var.pg_password}';"
      - sudo -u postgres psql -c "CREATE USER replicator REPLICATION LOGIN PASSWORD '${var.pg_replication_password}';"
      - systemctl reload postgresql
    ssh_authorized_keys:
      - ${var.ssh_public_key}
  USERDATA
}

# ── Cloud-init: standby node ──
resource "harvester_cloudinit_secret" "pg_standby" {
  name      = "postgresql-standby-cloudinit"
  namespace = var.namespace

  network_data = <<-NETDATA
    version: 2
    ethernets:
      enp1s0:
        addresses:
          - ${local.pg_standby_ip}/${local.pg_prefix}
        gateway4: ${var.vlans.data.gateway}
        nameservers:
          addresses:
            - ${var.vlans.data.gateway}
          search:
            - ${var.dns_domain}
  NETDATA

  user_data = <<-USERDATA
    #cloud-config
    hostname: postgres-ro
    fqdn: postgres-ro.${var.dns_domain}
    manage_etc_hosts: true
    packages:
      - postgresql-${var.pg_version}
    runcmd:
      - systemctl stop postgresql
      - rm -rf /var/lib/postgresql/${var.pg_version}/main
      - |
        sudo -u postgres pg_basebackup \
          -h postgres.${var.dns_domain} \
          -U replicator -P -R \
          -D /var/lib/postgresql/${var.pg_version}/main
      - systemctl start postgresql
    ssh_authorized_keys:
      - ${var.ssh_public_key}
  USERDATA
}

# ── Primary VM — DATA VLAN ──
resource "harvester_virtualmachine" "pg_primary" {
  name      = "${var.namespace}-pg-primary"
  namespace = var.namespace

  cpu    = 4
  memory = "8Gi"

  disk {
    name        = "rootdisk"
    type        = "disk"
    size        = "50Gi"
    bus         = "virtio"
    boot_order  = 1
    image       = "ubuntu-22.04-server-cloudimg-amd64"
    auto_delete = true
  }

  disk {
    name        = "pgdata"
    type        = "disk"
    size        = "200Gi"
    bus         = "virtio"
    auto_delete = false
  }

  network_interface {
    name         = "nic-data"
    network_name = harvester_network.vlans["data"].id
  }

  cloudinit {
    user_data_secret_name    = harvester_cloudinit_secret.pg_primary.name
    network_data_secret_name = harvester_cloudinit_secret.pg_primary.name
  }

  tags = {
    "role"       = "postgresql-primary"
    "service-ip" = local.pg_primary_ip
  }
}

# ── Standby VM — DATA VLAN ──
resource "harvester_virtualmachine" "pg_standby" {
  name      = "${var.namespace}-pg-standby"
  namespace = var.namespace

  cpu    = 4
  memory = "8Gi"

  disk {
    name        = "rootdisk"
    type        = "disk"
    size        = "50Gi"
    bus         = "virtio"
    boot_order  = 1
    image       = "ubuntu-22.04-server-cloudimg-amd64"
    auto_delete = true
  }

  disk {
    name        = "pgdata"
    type        = "disk"
    size        = "200Gi"
    bus         = "virtio"
    auto_delete = false
  }

  network_interface {
    name         = "nic-data"
    network_name = harvester_network.vlans["data"].id
  }

  cloudinit {
    user_data_secret_name    = harvester_cloudinit_secret.pg_standby.name
    network_data_secret_name = harvester_cloudinit_secret.pg_standby.name
  }

  tags = {
    "role"       = "postgresql-standby"
    "service-ip" = local.pg_standby_ip
  }

  depends_on = [harvester_virtualmachine.pg_primary]
}

output "pg_primary_ip" {
  value       = local.pg_primary_ip
  description = "PostgreSQL primary static IP — resolves as postgres.${var.dns_domain}"
}

output "pg_standby_ip" {
  value       = local.pg_standby_ip
  description = "PostgreSQL standby static IP — resolves as postgres-ro.${var.dns_domain}"
}

output "pg_dns_names" {
  value = {
    primary  = "postgres.${var.dns_domain}"
    readonly = "postgres-ro.${var.dns_domain}"
  }
  description = "DNS names for PostgreSQL — use these in connection strings"
}
